{
  "name": "markwise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "postinstall": "prisma generate",
    "reset:ble-ids": "tsx scripts/reset-ble-ids.ts",
    "migrate:ble-ids": "tsx scripts/migrate-ble-ids.ts",
    "migrate:ble-ids:rollback": "tsx -e \"import { rollbackMigration } from './scripts/migrate-ble-ids'; rollbackMigration().then(() => process.exit(0))\"",
    "migrate:ble-ids:rollback:institution": "tsx -e \"import { rollbackMigration } from './scripts/migrate-ble-ids'; rollbackMigration(process.argv[1]).then(() => process.exit(0))\"",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma db push --force-reset",
    "prisma:seed": "node prisma/seed.mjs",
    "ble:setup": "tsx scripts/setup-ble-system.ts",
    "ble:fix": "tsx scripts/fix-ble-ids.ts",
    "ble:stats": "tsx scripts/ble-stats.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.5",
    "@vercel/blob": "^2.3.3",
    "axios": "^1.13.5",
    "axios-cookiejar-support": "^6.0.5",
    "bcryptjs": "^3.0.3",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.34.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.564.0",
    "luxon": "^3.7.2",
    "next": "^16.2.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "otpauth": "^9.5.0",
    "pdfkit": "^0.18.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.8.1",
    "tough-cookie": "^6.0.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.17.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.2.3",
    "fast-check": "^4.7.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
}
